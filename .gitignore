# secrets
.env
secrets/
*.key
*.pem

# runtime/data
runtime/
logs/
*.log
*.jsonl

# data/ — ignore contents by default; track selected structure
data/*
!data/plans/
!data/workspaces/
!data/registry/
!data/notifications/
data/notifications/*.jsonl
!data/notifications/.gitkeep
data/registry/*
!data/registry/.gitkeep
!data/registry/generated_installed_tools.json

# Generated-tool dry-run evidence (local only; covered by data/* but listed for clarity)
data/generated_tool_dry_runs/

# Runtime plan JSON (keep optional .gitkeep)
data/plans/**/*.json
!data/plans/**/.gitkeep

# Task workspaces (keep .gitkeep per state folder)
data/workspaces/active/*
!data/workspaces/active/.gitkeep
data/workspaces/completed/*
!data/workspaces/completed/.gitkeep
data/workspaces/rejected/*
!data/workspaces/rejected/.gitkeep

# Python junk
__pycache__/
*.pyc
.venv/
venv/

# generated/pending tools
tools_pending/
tools_generated/
