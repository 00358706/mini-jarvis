# ──────────────────────────────────────────────────────────────────────────────
# Agentic Gateway — environment configuration
# Copy to .env, fill in values, never commit to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Network ───────────────────────────────────────────────────────────────────
# Set to your Tailscale 100.x.x.x address to restrict binding.
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
GATEWAY_API_KEY=change-me-before-use
# Optional role-separated keys (when set, only matching keys + GATEWAY_API_KEY work for that tier).
# GATEWAY_INPUT_API_KEY=
# GATEWAY_APPROVAL_API_KEY=
# GATEWAY_ADMIN_API_KEY=

# ── Local LLM (Ollama) ────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
# Used for intent classification — keep this small and fast (7B/8B).
CLASSIFIER_MODEL=llama3
# Used for LOCAL_LLM responses — can be the same or a larger model.
LOCAL_LLM_MODEL=llama3
# Max tokens the classifier is allowed to output. 5 is enough for a single token.
CLASSIFIER_MAX_TOKENS=5

# ── Cloud LLM (OpenRouter) ────────────────────────────────────────────────────
OPENROUTER_API_KEY=
# "openai/gpt-4o" or any OpenRouter model slug.
# "openrouter/auto" lets OpenRouter pick the best model per request.
CLOUD_MODEL=openai/gpt-4o

# ── Media Automation ──────────────────────────────────────────────────────────
RADARR_URL=http://localhost:7878
RADARR_API_KEY=
SONARR_URL=http://localhost:8989
SONARR_API_KEY=
SABNZBD_URL=http://localhost:8090
SABNZBD_API_KEY=

# ── Timeouts (seconds) ───────────────────────────────────────────────────────
OLLAMA_TIMEOUT=30.0
CLOUD_TIMEOUT=60.0
TOOL_TIMEOUT=15.0

# ── Policy (Phase 4) ─────────────────────────────────────────────────────────
# Allow cloud routing when heuristic sensitive-data patterns match (not recommended).
# CLOUD_ALLOW_SENSITIVE=false
# Enable exec()-based Python sandbox for proposed tool code (dev only).
# ENABLE_SANDBOX_PYTHON_EXEC=false
